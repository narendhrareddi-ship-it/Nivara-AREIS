# Copy these values into Streamlit Community Cloud → App settings → Secrets
# https://share.streamlit.io

DB_HOST = "your-db-host.supabase.co"
DB_PORT = "5432"
DB_NAME = "nivara"
DB_USER = "nivara"
DB_PASSWORD = "your-db-password"

# Backend APIs (must be public HTTPS URLs when dashboard runs on Streamlit Cloud)
ORCHESTRATOR_URL = "https://your-orchestrator.example.com"
VEO_MCP_URL = "https://your-veo-mcp.example.com"
OLLAMA_BASE_URL = "https://your-ollama.example.com"
