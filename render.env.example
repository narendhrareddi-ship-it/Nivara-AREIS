# Render environment — set DB_PASSWORD manually in dashboard

# Required secret (set in Render Dashboard → nivara-orchestrator → Environment):
# DB_PASSWORD = your Supabase database password

# These are now baked into render.yaml (auto-applied on blueprint sync):
# DB_HOST=aws-1-ap-south-1.pooler.supabase.com
# DB_USER=postgres.mxjhwjxxqtkwsrwtqwuc
# DB_NAME=postgres
# DB_SSLMODE=require

# Optional LLM (recommended — avoids stub responses):
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=...

# Verify after deploy:
# curl https://nivara-orchestrator.onrender.com/health
# → "db_connected": true, "agent_count": 20
