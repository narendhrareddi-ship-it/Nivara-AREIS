# NIVARA Production — Environment template (copy to .env, never commit)

# Market
DEFAULT_REGION=Bangalore
DEFAULT_STATE=Karnataka

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=media
USE_SUPABASE_STORAGE=true

# Postgres (Supabase pooler)
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-db-password

# Gemini Veo
GEMINI_API_KEY=your-gemini-api-key
VEO_MODEL=veo-3.1-generate-preview
VEO_MOCK=false

# Service URLs (local or Render HTTPS endpoints)
ORCHESTRATOR_URL=http://localhost:8000
VEO_MCP_URL=http://localhost:8006
SOCIAL_MCP_URL=http://localhost:8003
MEDIA_PUBLIC_BASE_URL=http://localhost:8006/media

# Ollama (optional — agents use stub text if offline)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Email (optional)
EMAIL_API_URL=
EMAIL_API_KEY=
