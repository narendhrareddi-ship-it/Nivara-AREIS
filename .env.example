# =============================================================================
# NIVARA REALTY — Phase 1 Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# --- Supabase (free tier: https://supabase.com) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Ollama (local, via Docker) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- N8N (self-hosted) ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_WEBHOOK_URL=http://localhost:5678

# --- Agent orchestrator ---
AGENT_LOG_LEVEL=INFO
DEFAULT_REGION=Chennai
DEFAULT_STATE="Tamil Nadu"

# --- MCP servers (local stubs) ---
CRM_MCP_PORT=8001
BROWSER_MCP_PORT=8002
SOCIAL_MCP_PORT=8003
WHATSAPP_MCP_PORT=8004
PIXVERSE_MCP_PORT=8006

# --- PixVerse AI (image-to-video) ---
# Get API key at https://platform.pixverse.ai
PIXVERSE_API_KEY=your_pixverse_api_key
PIXVERSE_MODEL=v5.5
PIXVERSE_QUALITY=720p
PIXVERSE_MOCK=true
MEDIA_STORAGE_PATH=media_storage
MEDIA_PUBLIC_BASE_URL=http://localhost:8006/media
PIXVERSE_MCP_URL=http://localhost:8006
SOCIAL_MCP_URL=http://localhost:8003

# --- Local PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nivara
DB_USER=nivara
DB_PASSWORD=changeme
