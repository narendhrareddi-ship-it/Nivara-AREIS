# =============================================================================
# NIVARA REALTY — Environment Variables
# =============================================================================

# --- Supabase (free tier: https://supabase.com) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Ollama (local, via Docker) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- N8N (self-hosted) ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_WEBHOOK_URL=http://localhost:5678

# --- Agent orchestrator ---
AGENT_LOG_LEVEL=INFO
DEFAULT_REGION=Chennai
DEFAULT_STATE="Tamil Nadu"

# --- MCP servers ---
CRM_MCP_PORT=8001
BROWSER_MCP_PORT=8002
SOCIAL_MCP_PORT=8003
WHATSAPP_MCP_PORT=8004
VEO_MCP_PORT=8006

# --- Gemini Veo (image-to-video) ---
# Get API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
VEO_MODEL=veo-3.1-generate-preview
VEO_MOCK=true
MEDIA_STORAGE_PATH=media_storage
MEDIA_PUBLIC_BASE_URL=http://localhost:8006/media
VEO_MCP_URL=http://localhost:8006
SOCIAL_MCP_URL=http://localhost:8003

# --- Supabase Postgres (direct connection — used by dashboard, agents, MCP) ---
# Find host/password: Supabase → Settings → Database
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password

# --- Local PostgreSQL (only if NOT using Supabase) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=nivara
# DB_USER=nivara
# DB_PASSWORD=changeme
