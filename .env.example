# =============================================================================
# NIVARA REALTY — Environment Variables
# =============================================================================

# --- Supabase (free tier: https://supabase.com) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Ollama (local, via Docker) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- N8N (self-hosted) ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_WEBHOOK_URL=http://localhost:5678

# --- Agent orchestrator ---
AGENT_LOG_LEVEL=INFO
DEFAULT_REGION=Bangalore
DEFAULT_STATE=Karnataka
ORCHESTRATOR_API_KEY=
WHATSAPP_MCP_URL=http://localhost:8004

# --- LLM (Ollama local + cloud fallback for production) ---
# LLM_PROVIDER: auto | ollama | groq | gemini | openrouter
LLM_PROVIDER=auto
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_API_KEY reused for Veo + LLM fallback
GEMINI_LLM_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# --- MCP servers ---
CRM_MCP_PORT=8001
BROWSER_MCP_PORT=8002
SOCIAL_MCP_PORT=8003
WHATSAPP_MCP_PORT=8004
VEO_MCP_PORT=8006

# --- Gemini Veo (image-to-video) ---
# Get API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
VEO_MODEL=veo-3.1-generate-preview
VEO_MOCK=true
MEDIA_STORAGE_PATH=media_storage
MEDIA_PUBLIC_BASE_URL=http://localhost:8006/media
VEO_MCP_URL=http://localhost:8006
SOCIAL_MCP_URL=http://localhost:8003

# --- Supabase Postgres (use Session pooler from cloud / Streamlit) ---
# Supabase → Settings → Database → Connection pooling → Session mode
# Host example: aws-1-ap-south-1.pooler.supabase.com
# User example: postgres.YOUR_PROJECT_REF
DB_HOST=aws-1-REGION.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-supabase-db-password

# --- Local PostgreSQL (only if NOT using Supabase) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=nivara
# DB_USER=nivara
# DB_PASSWORD=changeme
