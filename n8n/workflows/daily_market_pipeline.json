{
  "name": "daily_market_pipeline",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 6
            }
          ]
        }
      },
      "id": "trigger-daily-6am",
      "name": "Daily 6 AM Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8000/orchestrate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"task\": \"daily_market_analysis\",\n  \"region\": \"Bangalore\"\n}",
        "options": {
          "timeout": 300000
        }
      },
      "id": "call-agent-orchestrator",
      "name": "Trigger Full 20-Agent Pipeline",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        300
      ],
      "notes": "Runs all 20 agents (omit agents[] for full pipeline). Set ORCHESTRATOR_URL in n8n if not using host.docker.internal:8000."
    },
    {
      "id": "log-to-supabase",
      "name": "Log to Postgres CRM",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
        720,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "connection": "postgres_local",
        "query": "INSERT INTO crm_activity (lead_id, activity_type, title, description, performed_by, agent_name) VALUES (NULL, 'pipeline', 'Daily market pipeline', '20-agent Bangalore pipeline completed', 'n8n', 'CEO')"
      }
    },
    {
      "parameters": {
        "content": "## Daily Market Pipeline (Phase 5)\n\nRuns at 6 AM IST. Triggers the full 20-agent Bangalore pipeline via orchestrator :8000.\n\nConfigure Supabase Postgres credentials and ORCHESTRATOR_URL (Render HTTPS) in n8n.",
        "height": 180,
        "width": 360
      },
      "id": "sticky-note",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        200,
        80
      ]
    }
  ],
  "connections": {
    "Daily 6 AM Trigger": {
      "main": [
        [
          {
            "node": "Trigger Full 20-Agent Pipeline",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Trigger Full 20-Agent Pipeline": {
      "main": [
        [
          {
            "node": "Log to Postgres CRM",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "Asia/Kolkata"
  },
  "meta": {
    "templateCredsSetupCompleted": false
  }
}
