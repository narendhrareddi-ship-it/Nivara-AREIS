{
  "name": "nivara-social",
  "version": "0.2.0",
  "description": "Social media MCP for FB/IG/LinkedIn/X/YouTube with video support",
  "tools": [
    {
      "name": "publish_post",
      "description": "Publish to a social platform (stores in CRM with media support)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "platform": { "type": "string", "enum": ["facebook", "instagram", "linkedin", "twitter", "youtube"] },
          "content": { "type": "string" },
          "campaign_id": { "type": "string" },
          "project_id": { "type": "string" },
          "media_urls": { "type": "array", "items": { "type": "string" } },
          "media_type": { "type": "string", "enum": ["text", "image", "video"], "default": "text" },
          "media_asset_id": { "type": "string" }
        },
        "required": ["platform", "content"]
      }
    },
    {
      "name": "schedule_post",
      "description": "Schedule a social post with optional video",
      "inputSchema": {
        "type": "object",
        "properties": {
          "platform": { "type": "string" },
          "content": { "type": "string" },
          "scheduled_at": { "type": "string", "format": "date-time" },
          "media_urls": { "type": "array", "items": { "type": "string" } },
          "media_type": { "type": "string" }
        },
        "required": ["platform", "content", "scheduled_at"]
      }
    },
    {
      "name": "get_engagement",
      "description": "Get mock engagement metrics for a post",
      "inputSchema": {
        "type": "object",
        "properties": {
          "post_id": { "type": "string" }
        },
        "required": ["post_id"]
      }
    },
    {
      "name": "webhook_receiver",
      "description": "Simulate inbound social webhook event",
      "inputSchema": {
        "type": "object",
        "properties": {
          "platform": { "type": "string" },
          "event_type": { "type": "string" },
          "payload": { "type": "object" }
        },
        "required": ["platform", "event_type"]
      }
    }
  ]
}
